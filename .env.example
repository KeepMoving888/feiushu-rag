# ==============================
# Feishu RAG 项目配置模板
# 复制为 .env 后按需修改
# ==============================

# ------------------------------
# 1) 管理后台登录
# ------------------------------
# Streamlit Cloud 推荐默认 false（免登录直接可用）
ENABLE_ADMIN_LOGIN=false
ADMIN_PASSWORD=admin123

# ------------------------------
# 2) 飞书开放平台配置
# ------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BASE_URL=https://open.feishu.cn/open-apis

# ------------------------------
# 3) 文件与向量库配置
# ------------------------------
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=feishu_knowledge_base

# 文档分块参数（可按语料调优）
DOC_CHUNK_SIZE=700
DOC_CHUNK_OVERLAP=120

# ------------------------------
# 4) 嵌入模型配置（默认在线拉取 HuggingFace 模型）
# 如需本地模型，可改成 ./models/bge-m3
# ------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
# 可选值：gpu/cuda/cpu，Streamlit Cloud 建议 cpu
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# ------------------------------
# 5) 大模型模式开关（二选一）
#    api / ollama
# 无外网场景建议使用 ollama
# ------------------------------
LLM_MODE=ollama

# 通用推理参数
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ------------------------------
# 5A) 在线 API 模式（豆包/通义千问）
# 当 LLM_MODE=api 时生效
# ------------------------------
# 通义千问示例：
# LLM_API_PROVIDER=qwen
# LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_MODEL=qwen-plus

LLM_API_PROVIDER=qwen
LLM_API_KEY=
OPENAI_API_KEY=
LLM_API_MODEL=qwen-plus
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ------------------------------
# 5B) 本地 Ollama 模式
# 当 LLM_MODE=ollama 时生效
# ------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ------------------------------
# 6) 多维表格增量同步配置（可选）
# ------------------------------
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
BITABLE_MAX_RECORDS=1000

# admin 页面保存绑定配置时，调用后端管理接口地址（可选）
ADMIN_API_BASE_URL=http://127.0.0.1:8000
# ADMIN_API_TOKEN=
